---
import BaseLayout from '../../../layouts/base-layout.astro';
import { getMessages } from '../../i18n/get-messages';
import type { Locale } from '../../i18n/schemas/ui-messages';
import { getCollection } from 'astro:content';

type Props = {
	readonly locale: Locale;
};

const { locale } = Astro.props;
const messages = getMessages(locale);
const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout locale={locale} messages={messages} title={messages.blog.title} description={messages.blog.intro}>
	<section class="border-b border-white/10 px-6 py-24 sm:px-10 lg:px-16">
		<div class="mx-auto max-w-3xl">
			<p class="text-xs font-semibold uppercase tracking-[0.28em] text-accent">{messages.blog.eyebrow}</p>
			<h1 class="mt-4 font-serif text-4xl text-pearl sm:text-5xl">{messages.blog.title}</h1>
			{
				posts.length > 0 ? (
					<ul class="mt-12 space-y-8">
						{posts.map((post) => (
							<li class="glass-panel rounded-2xl p-6">
								<p class="text-xs uppercase tracking-wider text-mist">
									{post.data.pubDate.toLocaleDateString(locale === 'es' ? 'es-VE' : 'en-US', {
										year: 'numeric',
										month: 'short',
										day: 'numeric',
									})}
								</p>
								<h2 class="mt-2 font-serif text-2xl text-pearl">{post.data.title}</h2>
								<p class="mt-2 text-sm text-mist">{post.data.description}</p>
							</li>
						))}
					</ul>
				) : null
			}
		</div>
	</section>
</BaseLayout>
