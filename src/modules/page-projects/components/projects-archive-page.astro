---
import BaseLayout from '../../../layouts/base-layout.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { getMessages } from '../../i18n/get-messages';
import type { Locale } from '../../i18n/schemas/ui-messages';
import { resolveProjectCardForLocale } from '../../projects/utils/resolve-project-card-for-locale';
import { sortProjectEntries } from '../../projects/utils/sort-project-entries';

type Props = {
	readonly locale: Locale;
};

const { locale } = Astro.props;
const messages = getMessages(locale);
const projects: CollectionEntry<'projects'>[] = sortProjectEntries(await getCollection('projects'));
const homeHref: string = `/${locale}/`;
---

<BaseLayout
	locale={locale}
	messages={messages}
	title={messages.projectsArchive.title}
	description={messages.projectsArchive.intro}
>
	<section class="border-b border-white/10 px-6 py-24 sm:px-10 lg:px-16">
		<div class="mx-auto max-w-4xl">
			<p class="text-xs font-semibold uppercase tracking-[0.28em] text-accent">{messages.projects.eyebrow}</p>
			<h1 class="mt-4 font-serif text-4xl tracking-tight text-pearl sm:text-5xl">{messages.projectsArchive.title}</h1>
			<p class="mt-4 text-lg leading-relaxed text-mist">{messages.projectsArchive.intro}</p>
			<p class="mt-8">
				<a href={homeHref} class="text-sm font-medium text-accent underline-offset-4 transition hover:text-pearl hover:underline">
					{messages.projectsArchive.backHome}
				</a>
			</p>
			<ul class="mt-16 space-y-6">
				{
					projects.map((entry) => {
						const project = resolveProjectCardForLocale(entry, locale);
						return (
						<li class="glass-panel rounded-2xl p-6 sm:p-8">
							<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
								<div>
									<p class="text-xs font-semibold uppercase tracking-[0.2em] text-mist">{project.year}</p>
									<h2 class="mt-2 font-serif text-2xl text-pearl sm:text-3xl">{project.title}</h2>
									<p class="mt-3 text-sm leading-relaxed text-mist">{project.summary}</p>
								</div>
								<div class="flex shrink-0 flex-wrap gap-2 sm:justify-end">
									{project.repository ? (
										<a
											href={project.repository}
											class="rounded-full border border-white/15 px-3 py-1.5 text-xs font-semibold text-pearl/90 transition hover:border-accent/40 hover:text-accent"
											target="_blank"
											rel="noreferrer noopener"
										>
											{messages.projectsArchive.linkRepository}
										</a>
									) : null}
									{project.link ? (
										<a
											href={project.link}
											class="rounded-full border border-accent/35 bg-accent/10 px-3 py-1.5 text-xs font-semibold text-accent transition hover:bg-accent/20"
											target="_blank"
											rel="noreferrer noopener"
										>
											{messages.projectsArchive.linkLive}
										</a>
									) : null}
								</div>
							</div>
							<div class="mt-6 grid gap-4 border-t border-white/10 pt-6 sm:grid-cols-2">
								<div>
									<p class="text-xs font-semibold uppercase tracking-wider text-accent/90">{messages.projects.card.problemSolved}</p>
									<p class="mt-1 text-sm text-pearl/90">{project.problemSolved}</p>
								</div>
								<div>
									<p class="text-xs font-semibold uppercase tracking-wider text-accent/90">{messages.projects.card.architecture}</p>
									<p class="mt-1 text-sm text-pearl/90">{project.architectureUsed}</p>
								</div>
							</div>
							<ul class="mt-6 flex flex-wrap gap-2" aria-label={messages.projects.card.techStackAria}>
								{project.techStack.map((tech: string) => (
									<li class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-medium text-pearl/85">
										{tech}
									</li>
								))}
							</ul>
						</li>
						);
					})
				}
			</ul>
		</div>
	</section>
</BaseLayout>
