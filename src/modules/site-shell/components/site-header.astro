---
import { Download } from '@lucide/astro';
import type { UiMessages } from '../../i18n/schemas/ui-messages';
import { publicIdentity } from '../constants/public-identity';
import { LanguageSwitcher } from './language-switcher';

type Props = {
	readonly messages: UiMessages;
	readonly pathname: string;
};

const { messages, pathname } = Astro.props;
const { nav, a11y, languageSwitcher } = messages;
const localePrefix: string = `/${messages.locale}`;
const localeHomeHref: string = `${localePrefix}/`;
const normalizedPathname: string = pathname.endsWith('/') ? pathname : `${pathname}/`;
const isHomePath: boolean = normalizedPathname === localeHomeHref;
function buildSectionHref(sectionId: string): string {
	if (isHomePath) {
		return `#${sectionId}`;
	}
	return `${localeHomeHref}#${sectionId}`;
}
const navItems: readonly { href: string; label: string }[] = [
	{ href: buildSectionHref('leadership'), label: nav.leadership },
	{ href: buildSectionHref('work'), label: nav.work },
	{ href: buildSectionHref('contact'), label: nav.contact },
] as const;
const rawCvUrl: string | undefined = import.meta.env.PUBLIC_CV_URL;
const cvHref: string = typeof rawCvUrl === 'string' && rawCvUrl.length > 0 ? rawCvUrl : '/cv.pdf';
const isExternalCv: boolean = cvHref.startsWith('http://') || cvHref.startsWith('https://');
---

<header
	class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-void/75 backdrop-blur-xl supports-[backdrop-filter]:bg-void/55"
>
	<div class="mx-auto flex max-w-5xl items-center justify-between gap-3 px-6 py-4 sm:px-10 lg:px-16">
		<a
			href={isHomePath ? '#top' : localeHomeHref}
			class="group shrink-0 font-serif text-lg font-semibold tracking-tight text-pearl transition duration-200 hover:text-accent"
		>
			<span
				class="block text-xs font-sans font-medium uppercase tracking-[0.28em] text-mist transition duration-200 group-hover:text-accent/90"
			>
				{nav.portfolioLabel}
			</span>
			{publicIdentity.fullName}
		</a>
		<nav
			aria-label={a11y.navPrimary}
			class="flex max-w-[min(100%,420px)] flex-1 justify-end gap-2 overflow-x-auto pb-1 sm:max-w-[min(100%,520px)] sm:gap-3 md:max-w-none md:justify-center md:overflow-visible md:pb-0"
		>
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class="shrink-0 rounded-full border border-white/10 px-2.5 py-1.5 text-[11px] font-medium text-pearl/90 transition duration-200 hover:-translate-y-0.5 hover:border-accent/55 hover:bg-accent/10 hover:text-pearl hover:shadow-[0_10px_28px_rgba(77,140,238,0.18)] sm:px-3 sm:text-xs md:border-transparent md:px-2.5 md:py-1.5 md:text-sm md:text-mist md:hover:text-pearl lg:px-3"
					>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="flex shrink-0 items-center gap-2">
			<LanguageSwitcher client:load currentLocale={messages.locale} pathname={pathname} copy={languageSwitcher} />
			<a
				href={cvHref}
				class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/[0.04] px-2.5 py-2 text-xs font-semibold text-pearl transition duration-200 hover:-translate-y-0.5 hover:border-accent/50 hover:bg-accent/15 hover:text-pearl hover:shadow-[0_10px_28px_rgba(77,140,238,0.2)] sm:gap-2 sm:px-3"
				aria-label={nav.downloadCv}
				download={isExternalCv ? undefined : true}
				rel={isExternalCv ? 'noreferrer noopener' : undefined}
				target={isExternalCv ? '_blank' : undefined}
			>
				<Download class="size-4 shrink-0 text-accent" aria-hidden="true" />
				<span class="hidden sm:inline">{nav.downloadCv}</span>
			</a>
			<a
				href={buildSectionHref('contact')}
				class="hidden rounded-full border border-accent/45 bg-accent px-4 py-2 text-xs font-semibold uppercase tracking-wide text-white shadow-[0_8px_24px_rgba(77,140,238,0.35)] transition duration-200 hover:-translate-y-0.5 hover:brightness-110 sm:inline-flex"
			>
				{nav.book}
			</a>
		</div>
	</div>
</header>
<div class="h-[72px]" aria-hidden="true"></div>
