---
import type { UiMessages } from '../../i18n/schemas/ui-messages';
import { publicIdentity } from '../constants/public-identity';
import { LanguageSwitcher } from './language-switcher';

type Props = {
	readonly messages: UiMessages;
	readonly pathname: string;
};

const { messages, pathname } = Astro.props;
const { nav, a11y, languageSwitcher } = messages;
const localePrefix: string = `/${messages.locale}`;
const localeHomeHref: string = `${localePrefix}/`;
const normalizedPathname: string = pathname.endsWith('/') ? pathname : `${pathname}/`;
const isHomePath: boolean = normalizedPathname === localeHomeHref;
function buildSectionHref(sectionId: string): string {
	if (isHomePath) {
		return `#${sectionId}`;
	}
	return `${localeHomeHref}#${sectionId}`;
}
const navItems: readonly { href: string; label: string }[] = [
	{ href: buildSectionHref('leadership'), label: nav.leadership },
	{ href: buildSectionHref('work'), label: nav.work },
	{ href: `${localePrefix}/projects/`, label: nav.allProjects },
	{ href: `${localePrefix}/services/`, label: nav.services },
	{ href: buildSectionHref('contact'), label: nav.contact },
] as const;
---

<header
	class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-void/75 backdrop-blur-xl supports-[backdrop-filter]:bg-void/55"
>
	<div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-6 py-4 sm:px-10 lg:px-16">
		<a
			href={isHomePath ? '#top' : localeHomeHref}
			class="group shrink-0 font-serif text-lg tracking-tight text-pearl transition hover:text-accent"
		>
			<span
				class="block text-xs font-sans font-medium uppercase tracking-[0.35em] text-mist group-hover:text-accent/80"
			>
				{nav.portfolioLabel}
			</span>
			{publicIdentity.fullName}
		</a>
		<nav
			aria-label={a11y.navPrimary}
			class="flex max-w-[min(100%,420px)] flex-1 justify-end gap-2 overflow-x-auto pb-1 sm:max-w-[min(100%,520px)] sm:gap-3 md:max-w-none md:justify-center md:overflow-visible md:pb-0"
		>
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class="shrink-0 rounded-full border border-white/10 px-2.5 py-1.5 text-[11px] font-medium text-pearl/90 transition hover:border-accent/40 hover:text-pearl sm:px-3 sm:text-xs md:border-transparent md:px-0 md:py-0 md:text-sm md:text-mist md:hover:text-pearl"
					>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="flex shrink-0 items-center gap-2">
			<LanguageSwitcher client:load currentLocale={messages.locale} pathname={pathname} copy={languageSwitcher} />
			<a
				href={buildSectionHref('contact')}
				class="hidden rounded-full border border-accent/40 bg-accent/10 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-accent transition hover:bg-accent/20 sm:inline-flex"
			>
				{nav.book}
			</a>
		</div>
	</div>
</header>
<div class="h-[72px]" aria-hidden="true"></div>
