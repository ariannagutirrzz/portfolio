---
import type { UiMessages } from '../../i18n/schemas/ui-messages';
import { blogIndexPath } from '../../i18n/paths';
import { publicIdentity } from '../constants/public-identity';

type Props = {
	readonly messages: UiMessages;
};

const { messages } = Astro.props;
const year: number = new Date().getFullYear();
const blogHref: string = blogIndexPath(messages.locale);
---

<footer class="border-t border-white/10 px-6 py-16 sm:px-10 lg:px-16">
	<div class="mx-auto flex max-w-6xl flex-col gap-10 md:flex-row md:items-center md:justify-between">
		<div>
			<p class="font-serif text-xl text-pearl">Arianna</p>
			<p class="mt-2 max-w-md text-sm leading-relaxed text-mist">
				{messages.site.metaDescription}
			</p>
		</div>
		<div class="flex flex-col gap-3 text-sm text-mist md:items-end">
			<a class="transition hover:text-pearl" href={blogHref}>
				{messages.footer.writing}
			</a>
			<a class="transition hover:text-pearl" href={`mailto:${publicIdentity.primaryEmail}`}>
				{publicIdentity.primaryEmail}
			</a>
			<p class="text-xs uppercase tracking-wider text-mist/70">
				© {year} — {messages.footer.crafted}
			</p>
		</div>
	</div>
</footer>
