---
import type { UiMessages } from '../../i18n/schemas/ui-messages';
import { HeroGlassPanelMotion } from './hero-glass-panel-motion';
import { HeroInteractiveBackdrop } from './hero-interactive-backdrop';
import { HeroLeftStackMotion } from './hero-left-stack-motion';

type Props = {
	readonly messages: UiMessages;
};

const { messages } = Astro.props;
---

<section
	class="relative isolate min-h-[92vh] overflow-hidden border-b border-white/10 px-6 pb-24 pt-28 sm:px-10 lg:px-16"
	aria-labelledby="hero-heading"
	id="top"
>
	<div class="absolute inset-0 bg-gradient-to-b from-ink via-void to-void" aria-hidden="true"></div>
	<HeroInteractiveBackdrop client:load />
	<div class="relative z-10 mx-auto flex max-w-6xl flex-col gap-14 lg:flex-row lg:items-end lg:justify-between">
		<HeroLeftStackMotion client:load hero={messages.hero} />
		<HeroGlassPanelMotion client:load />
	</div>
</section>
