---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import SiteFooter from '../modules/site-shell/components/site-footer.astro';
import SiteHeader from '../modules/site-shell/components/site-header.astro';
import { publicIdentity } from '../modules/site-shell/constants/public-identity';
import type { Locale } from '../modules/i18n/schemas/ui-messages';
import type { UiMessages } from '../modules/i18n/schemas/ui-messages';

type Props = {
	readonly locale: Locale;
	readonly messages: UiMessages;
	readonly title: string;
	readonly description?: string;
};

const { locale, messages, title, description = messages.site.metaDescription } = Astro.props;
const pageTitle: string = title === messages.site.title ? title : messages.site.titleTemplate.replace('%s', title);
const canonicalUrl: string = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
const siteOrigin: string = (Astro.site ?? Astro.url).origin;
const personUrl: string = siteOrigin;
const jsonLd: string = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: publicIdentity.fullName,
	jobTitle: messages.site.personJobTitle,
	url: personUrl,
	description: messages.site.metaDescription,
	email: publicIdentity.primaryEmail,
	sameAs: [publicIdentity.linkedInUrl],
	inLanguage: locale,
	knowsAbout: [...messages.site.personKnowsAbout],
});
const alternateEn: string = new URL('/en/', siteOrigin).href;
const alternateEs: string = new URL('/es/', siteOrigin).href;
const whatsappNumber: string = publicIdentity.phone.replace(/[^0-9]/g, '');
const whatsappHref: string = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(messages.whatsappWidget.message)}`;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#080c12" />
		<ClientRouter />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content={locale === 'es' ? 'es_VE' : 'en_US'} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateEn} />
		<link rel="alternate" hreflang="es" href={alternateEs} />
		<link rel="alternate" hreflang="x-default" href={alternateEs} />
		<title>{pageTitle}</title>
		<script is:inline type="application/ld+json" set:html={jsonLd} />
	</head>
	<body class="min-h-screen bg-void">
		<a
			href="#main"
			class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-full bg-accent px-4 py-2 text-sm font-semibold text-white opacity-0 transition focus:translate-y-0 focus:opacity-100"
		>
			{messages.a11y.skipToContent}
		</a>
		<SiteHeader messages={messages} pathname={Astro.url.pathname} />
		<main id="main">
			<slot />
		</main>
		<a
			href={whatsappHref}
			target="_blank"
			rel="noreferrer noopener"
			aria-label={messages.whatsappWidget.label}
			class="fixed bottom-5 right-5 z-[70] inline-flex items-center gap-2 rounded-full border border-emerald-400/40 bg-emerald-500/15 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-emerald-300 shadow-[0_8px_30px_rgba(16,185,129,0.2)] backdrop-blur transition hover:bg-emerald-500/25 hover:text-emerald-200"
		>
			<svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-current">
				<path d="M20.52 3.48A11.82 11.82 0 0 0 12.08 0C5.5 0 .16 5.34.16 11.92a11.8 11.8 0 0 0 1.6 5.95L0 24l6.32-1.66a11.86 11.86 0 0 0 5.76 1.48h.01c6.58 0 11.92-5.35 11.92-11.93 0-3.18-1.24-6.16-3.49-8.41Zm-8.44 18.33h-.01a9.86 9.86 0 0 1-5.03-1.38l-.36-.22-3.75.98 1-3.65-.24-.38a9.84 9.84 0 0 1-1.52-5.25c0-5.45 4.44-9.9 9.9-9.9 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.9 6.99c0 5.46-4.45 9.9-9.88 9.91Zm5.44-7.42c-.3-.15-1.78-.88-2.05-.98-.28-.1-.48-.15-.68.15-.2.3-.78.98-.96 1.18-.18.2-.35.22-.65.08-.3-.15-1.28-.47-2.44-1.5a9.06 9.06 0 0 1-1.69-2.1c-.18-.3-.02-.46.13-.61.14-.14.3-.35.45-.53.15-.17.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.68-1.64-.93-2.25-.24-.58-.48-.5-.68-.5h-.58c-.2 0-.53.08-.8.38s-1.05 1.03-1.05 2.5c0 1.48 1.08 2.9 1.23 3.1.15.2 2.12 3.24 5.13 4.54.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.78-.73 2.03-1.43.25-.7.25-1.3.17-1.43-.07-.13-.27-.2-.57-.35Z" />
			</svg>
			<span class="hidden sm:inline">{messages.whatsappWidget.label}</span>
		</a>
		<SiteFooter messages={messages} />
	</body>
</html>
